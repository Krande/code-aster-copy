#       AVEC PROPRIETES VARIABLES
# MAILLES : TRIA3, QUAD4
#

DEBUT(CODE="OUI", ERREUR=_F(ALARME="EXCEPTION"))

#
# LECTURE DU MAILLAGE ----------------------------------------------
#

MAIL = LIRE_MAILLAGE(FORMAT="MED").convertToCubic()

#
# DEFINITION DES CHARGEMENTS ET DU MATERIAU ------------------------
#

TGAUCHE = DEFI_FONCTION(
    NOM_RESU="TEMP",
    NOM_PARA="INST",
    VALE=(0.0e0, 200.0e0, 10.0e0, 200.0e0, 10.001e0, 100.0e0, 100.0e0, 100.0e0),
)

TDROITE = DEFI_FONCTION(NOM_RESU="TEMP", NOM_PARA="INST", VALE=(0.0e0, 100.0e0, 100.0e0, 100.0e0))

CONDUC = DEFI_FONCTION(
    NOM_PARA="TEMP",
    NOM_RESU="LAMBDA",
    VALE=(0.0, 2.0e2, 500.0, 7.0e2),
    PROL_DROITE="LINEAIRE",
    PROL_GAUCHE="LINEAIRE",
)

ENTHAL = DEFI_FONCTION(
    NOM_PARA="TEMP",
    NOM_RESU="CP",
    VALE=(0.0, 0.0, 500.0, 4000.0e6),
    PROL_DROITE="LINEAIRE",
    PROL_GAUCHE="LINEAIRE",
)

MATER = DEFI_MATERIAU(THER_NL=_F(LAMBDA=CONDUC, BETA=ENTHAL))

#
# AFFECTATIONS: MATERIAU, MODELE, CHARGEMENT ----------------------
#


CHMAT = AFFE_MATERIAU(MAILLAGE=MAIL, AFFE=_F(TOUT="OUI", MATER=MATER))

MOTH = AFFE_MODELE(MAILLAGE=MAIL, AFFE=_F(TOUT="OUI", MODELISATION="PLAN", PHENOMENE="THERMIQUE"))

CHTH = AFFE_CHAR_THER_F(
    MODELE=MOTH,
    TEMP_IMPO=(_F(GROUP_MA="MA_GAU", TEMP=TGAUCHE), _F(GROUP_MA="MA_DRO", TEMP=TDROITE)),
)

CHFAKE = AFFE_CHAR_THER(
    MODELE=MOTH, SOURCE=_F(GROUP_MA="2D", SOUR=0.0), FLUX_REP=_F(GROUP_MA="MA_BAS", FLUN=0.0)
)

#
# DEFINITION DE LA STATEGIE DE CALCUL -----------------------------
#

LR8 = DEFI_LIST_REEL(
    DEBUT=0.0,
    INTERVALLE=(
        _F(JUSQU_A=1.0e-3, NOMBRE=10),
        _F(JUSQU_A=1.0e-2, NOMBRE=9),
        _F(JUSQU_A=1.0e-1, NOMBRE=9),
        _F(JUSQU_A=1.0e0, NOMBRE=9),
        _F(JUSQU_A=10.0e0, NOMBRE=9),
        _F(JUSQU_A=13.0e0, NOMBRE=3),
    ),
)

#
# RESOLUTION ------------------------------------------------------
#

TEMPE = THER_NON_LINE(
    MODELE=MOTH,
    ETAT_INIT=_F(VALE=100.0),
    INCREMENT=_F(LIST_INST=LR8),
    CHAM_MATER=CHMAT,
    EXCIT=(_F(CHARGE=CHTH), _F(CHARGE=CHFAKE)),
)

TEMP_10 = CREA_CHAMP(
    OPERATION="EXTR", TYPE_CHAM="NOEU_TEMP_R", NOM_CHAM="TEMP", RESULTAT=TEMPE, INST=10.0
)

TEMP_13 = CREA_CHAMP(
    OPERATION="EXTR", TYPE_CHAM="NOEU_TEMP_R", NOM_CHAM="TEMP", RESULTAT=TEMPE, INST=13.0
)

#
# ANALYSE DES RESULTATS -------------------------------------------
#

TEST_RESU(
    CHAM_NO=(
        _F(
            GROUP_NO="N8",
            NOM_CMP="TEMP",
            PRECISION=0.02,
            CHAM_GD=TEMP_10,
            VALE_CALC=175.53112846203035,
            VALE_REFE=176.16499999999999,
            REFERENCE="NON_DEFINI",
        ),
        _F(
            GROUP_NO="N10",
            NOM_CMP="TEMP",
            PRECISION=0.02,
            CHAM_GD=TEMP_10,
            VALE_CALC=175.53116991460294,
            VALE_REFE=176.16499999999999,
            REFERENCE="NON_DEFINI",
        ),
        _F(
            GROUP_NO="N12",
            NOM_CMP="TEMP",
            PRECISION=0.02,
            CHAM_GD=TEMP_10,
            VALE_CALC=175.53099528734472,
            VALE_REFE=176.16499999999999,
            REFERENCE="NON_DEFINI",
        ),
        _F(
            GROUP_NO="N8",
            NOM_CMP="TEMP",
            PRECISION=0.02,
            CHAM_GD=TEMP_13,
            VALE_CALC=128.80053886135073,
            VALE_REFE=128.125,
            REFERENCE="NON_DEFINI",
        ),
        _F(
            GROUP_NO="N10",
            NOM_CMP="TEMP",
            PRECISION=0.02,
            CHAM_GD=TEMP_13,
            VALE_CALC=128.76152111981062,
            VALE_REFE=128.125,
            REFERENCE="NON_DEFINI",
        ),
        _F(
            GROUP_NO="N12",
            NOM_CMP="TEMP",
            PRECISION=0.02,
            CHAM_GD=TEMP_13,
            VALE_CALC=129.14610679684105,
            VALE_REFE=128.125,
            REFERENCE="NON_DEFINI",
        ),
        _F(
            GROUP_NO="N75",
            CRITERE="ABSOLU",
            NOM_CMP="TEMP",
            PRECISION=3.0,
            CHAM_GD=TEMP_13,
            VALE_CALC=100.19724608160341,
            VALE_REFE=100.134,
            REFERENCE="NON_DEFINI",
        ),
        _F(
            GROUP_NO="N77",
            CRITERE="ABSOLU",
            NOM_CMP="TEMP",
            PRECISION=3.0,
            CHAM_GD=TEMP_13,
            VALE_CALC=100.19727423248032,
            VALE_REFE=100.134,
            REFERENCE="NON_DEFINI",
        ),
    )
)

FIN()
#
