from code_aster.Commands import *
from code_aster import CA
from ssnp175a_func import create_grp_2d

DEBUT(CODE="OUI", DEBUG=_F(SDVERI="OUI"), INFO=1)

Mail0 = LIRE_MAILLAGE(UNITE=20, FORMAT="MED").convertToCubic()

Mail = create_grp_2d(Mail0)


Mail = MODI_MAILLAGE(
    reuse=Mail,
    MAILLAGE=Mail,
    ORIE_PEAU=_F(GROUP_MA_PEAU=("LIAISON_Haut", "LIAISON_Bas", "Encast", "Pres")),
)

MODI = AFFE_MODELE(
    MAILLAGE=Mail,
    AFFE=(
        _F(
            GROUP_MA=("Haut", "LIAISON_Haut", "Pres", "Sym_Haut"),
            PHENOMENE="MECANIQUE",
            MODELISATION="D_PLAN",
        ),
        _F(
            GROUP_MA=("Bas", "LIAISON_Bas", "Encast", "Sym_Bas"),
            PHENOMENE="MECANIQUE",
            MODELISATION="D_PLAN",
        ),
    ),
)

E = 2000.0

mat1 = DEFI_MATERIAU(ELAS=_F(E=E, NU=0.3))

AFFE = AFFE_MATERIAU(MAILLAGE=Mail, MODELE=MODI, AFFE=_F(TOUT="OUI", MATER=mat1))

RACCORD = AFFE_CHAR_MECA(
    MODELE=MODI,
    INFO=1,
    LIAISON_MASSIF=_F(
        GROUP_MA_ESCL="LIAISON_Haut",
        GROUP_MA_MAIT="LIAISON_Bas",
        METHODE="LAGRANGIEN",
        TYPE_APPA="PANG",
    ),
)


CINE_FEM = AFFE_CHAR_CINE(
    MODELE=MODI,
    MECA_IMPO=(_F(GROUP_MA=("Sym_Haut", "Sym_Bas"), DX=0), _F(GROUP_MA=("Encast",), DY=0)),
)

CHAR_PRES = AFFE_CHAR_MECA(MODELE=MODI, PRES_REP=_F(GROUP_MA="Pres", PRES=25))

lisi = DEFI_LIST_REEL(DEBUT=0, INTERVALLE=_F(JUSQU_A=1, PAS=0.5))

RAMPE = DEFI_FONCTION(NOM_PARA="INST", VALE=(0, 0, 1, 1))


RES = MECA_NON_LINE(
    INFO=1,
    MODELE=MODI,
    CHAM_MATER=AFFE,
    EXCIT=(_F(CHARGE=CINE_FEM), _F(CHARGE=CHAR_PRES, FONC_MULT=RAMPE), _F(CHARGE=RACCORD)),
    NEWTON=_F(MATRICE="TANGENTE", REAC_ITER=1),
    INCREMENT=_F(LIST_INST=lisi),
    COMPORTEMENT=_F(RELATION="ELAS", DEFORMATION="PETIT", TOUT="OUI"),
    SOLVEUR=_F(METHODE="MUMPS", RESI_RELA=1.0e-6, PCENT_PIVOT=30),
    CONVERGENCE=_F(RESI_GLOB_MAXI=1.0e-6, ITER_GLOB_MAXI=3),
)

RES = CALC_CHAMP(
    reuse=RES, RESULTAT=RES, CONTRAINTE=("SIEF_NOEU", "SIEF_ELNO", "SIGM_NOEU", "SIGM_ELNO")
)


TEST_RESU(
    RESU=(
        _F(
            INST=1.0,
            TYPE_TEST="MIN",
            RESULTAT=RES,
            REFERENCE="ANALYTIQUE",
            NOM_CHAM="SIEF_NOEU",
            LEGENDE="SIEF_NOEU",
            NOM_CMP="SIYY",
            VALE_REFE=-25.0,
            VALE_CALC=-25.0000000000001,
            PRECISION=0.05,
        ),
        _F(
            INST=1.0,
            TYPE_TEST="MAX",
            RESULTAT=RES,
            REFERENCE="ANALYTIQUE",
            NOM_CHAM="SIEF_NOEU",
            LEGENDE="SIEF_NOEU",
            NOM_CMP="SIYY",
            VALE_REFE=-25.0,
            VALE_CALC=-24.99999999999956,
            PRECISION=1e-4,
        ),
        _F(
            INST=1.0,
            TYPE_TEST="MIN",
            RESULTAT=RES,
            REFERENCE="ANALYTIQUE",
            NOM_CHAM="SIGM_NOEU",
            LEGENDE="SIYY",
            NOM_CMP="SIYY",
            VALE_REFE=-25.0,
            VALE_CALC=-25.0000000000001,
            PRECISION=1e-4,
        ),
        _F(
            INST=1.0,
            TYPE_TEST="MAX",
            RESULTAT=RES,
            REFERENCE="ANALYTIQUE",
            NOM_CHAM="SIGM_NOEU",
            LEGENDE="SIYY",
            NOM_CMP="SIYY",
            VALE_REFE=-25.0,
            VALE_CALC=-24.99999999999956,
            PRECISION=1e-4,
        ),
        _F(
            INST=1.0,
            TYPE_TEST="MIN",
            RESULTAT=RES,
            REFERENCE="ANALYTIQUE",
            NOM_CHAM="SIGM_NOEU",
            LEGENDE="SIXY",
            NOM_CMP="SIXY",
            CRITERE="ABSOLU",
            ORDRE_GRANDEUR=1e-5,
            VALE_REFE=0.0,
            VALE_CALC=0.0,
        ),
        _F(
            INST=1.0,
            TYPE_TEST="MAX",
            RESULTAT=RES,
            REFERENCE="ANALYTIQUE",
            NOM_CHAM="SIGM_NOEU",
            LEGENDE="SIXY",
            NOM_CMP="SIXY",
            CRITERE="ABSOLU",
            ORDRE_GRANDEUR=1e-5,
            VALE_REFE=0.0,
            VALE_CALC=0.0,
        ),
    )
)

FIN()
