# Lecture des chargements sismiques:
# recherche NUME_ORDRE correspondant a NOM_CAS: attention que nume_ordre commence par 1
nume_ordre_vale_tota = [list(sismique.getAccessParameters()["NOM_CAS"]).index("TOTA") + 1]
print("nume_ordre_vale_tota:", nume_ordre_vale_tota)

nume_ordre_part_dyna = [list(sismique_dyn.getAccessParameters()["NOM_CAS"]).index("TOTA") + 1]
print("nume_ordre_part_dyna:", nume_ordre_part_dyna)

nume_ordre_part_qs = [list(sismique_qs.getAccessParameters()["NOM_CAS"]).index("TOTA") + 1]
print("nume_ordre_part_qs:", nume_ordre_part_qs)


table = CREA_TABLE(
    RESU=_F(
        RESULTAT=sismique,
        NUME_ORDRE=nume_ordre_vale_tota,
        NOM_CHAM="EFGE_ELNO",
        TOUT="OUI",
        NOM_CMP=("MT", "MFY", "MFZ"),
    )
)
sismique_values = table.EXTR_TABLE().values()
mfy_sismique = np.array(sismique_values["MFY"])
mfz_sismique = np.array(sismique_values["MFZ"])

table = CREA_TABLE(
    RESU=_F(
        RESULTAT=sismique_dyn,
        NUME_ORDRE=nume_ordre_part_dyna,
        # NOM_CAS = "PART_DYNA",
        NOM_CHAM="EFGE_ELNO",
        TOUT="OUI",
        NOM_CMP=("MT", "MFY", "MFZ"),
    )
)
sismique_dyn_values = table.EXTR_TABLE().values()
mfy_sismique_dyn = np.array(sismique_dyn_values["MFY"])
mfz_sismique_dyn = np.array(sismique_dyn_values["MFZ"])

table = CREA_TABLE(
    RESU=_F(
        RESULTAT=sismique_qs,
        NUME_ORDRE=nume_ordre_part_qs,
        # NOM_CAS = "PART_QS",
        NOM_CHAM="EFGE_ELNO",
        TOUT="OUI",
        NOM_CMP=("MT", "MFY", "MFZ"),
    )
)
sismique_qs_values = table.EXTR_TABLE().values()
mfy_sismique_qs = np.array(sismique_qs_values["MFY"])
mfz_sismique_qs = np.array(sismique_qs_values["MFZ"])

