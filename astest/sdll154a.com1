# TEST_RESU resuPostRocheRCCMRX

alpha = 1.0
RP02_MIN = 128e6
RM_MIN = 410e6
RP02_MOY = 163e6
S = alpha * (0.426 * RP02_MIN + 0.032 * RM_MIN)
sigv = 2 * S * (RP02_MOY / RP02_MIN)

rmMax = 0.0
rsMax = 0.0
pression = 1e6
# sigp = 0.87*pression*(rayon-ep)/ep
sigp = 0.87 * pression * (0.01 - 0.005) / 0.005


gOptRef = (
    (sigv - sigp) * (1 + rmMax) / (E * (epsiMp(sigv) - epsiMp(sigp)) + (sigv - sigp) * (1 + rmMax))
)
gsOptRef = (
    (sigv - sigp) * (1 + rsMax) / (E * (epsiMp(sigv) - epsiMp(sigp)) + (sigv - sigp) * (1 + rsMax))
)

# tout RCCM_RX = OUI
post_roche_analytic_RCCM = PostRocheAnalytic(
    mfy_poids_propre,
    mt_deplacement_impose,
    zeros,  # mfy_sismique_dyn,
    zeros,  # mfz_sismique_dyn,
    zeros,  # mfy_sismique_qs,
    zeros,  # mfz_sismique_qs,
    zeros,  # mfy_sismique,
    zeros,  # mfz_sismique,
    pression=1e6,
    RCCM=True,
)
post_roche_analytic_RCCM.donne_abattement(gOptRef, gsOptRef)
post_roche_analytic_RCCM.calcul_sigma_eq()


