import numpy as np

POURSUITE(CODE="OUI", DEBUG=_F(SDVERI="OUI"))

# calcul des references pour POST_ROCHE, on extrait uniquement les valeurs de MT, MFY et MFZ non nulles

table = CREA_TABLE(
    RESU=_F(RESULTAT=poids_propre, NOM_CHAM="EFGE_ELNO", TOUT="OUI", NOM_CMP=("MT", "MFY", "MFZ"))
)
poids_propre_values = table.EXTR_TABLE().values()
mfy_poids_propre = np.array(poids_propre_values["MFY"])

table = CREA_TABLE(
    RESU=_F(
        RESULTAT=deplacement_impose, NOM_CHAM="EFGE_ELNO", TOUT="OUI", NOM_CMP=("MT", "MFY", "MFZ")
    )
)
deplacement_impose_values = table.EXTR_TABLE().values()
mt_deplacement_impose = np.array(deplacement_impose_values["MT"])

table = CREA_TABLE(
    RESU=_F(
        RESULTAT=dilatation_thermique,
        NOM_CHAM="EFGE_ELNO",
        TOUT="OUI",
        NOM_CMP=("MT", "MFY", "MFZ"),
    )
)
dilatation_thermique_values = table.EXTR_TABLE().values()


from sdll154a_fonctions import PostRocheAnalytic

zeros = np.zeros([4])
# tout
post_roche_analytic = PostRocheAnalytic(
    mfy_poids_propre,
    mt_deplacement_impose,
    zeros,  # mfy_sismique_dyn,
    zeros,  # mfz_sismique_dyn,
    zeros,  # mfy_sismique_qs,
    zeros,  # mfz_sismique_qs,
    zeros,  # mfy_sismique,
    zeros,  # mfz_sismique,
    pression=1e6,
)
post_roche_analytic.calcul_ressort()
post_roche_analytic.calcul_abattement()
post_roche_analytic.calcul_sigma_eq()

# tout + coude
post_roche_analytic_Coude = PostRocheAnalytic(
    mfy_poids_propre,
    mt_deplacement_impose,
    zeros,  # mfy_sismique_dyn,
    zeros,  # mfz_sismique_dyn,
    zeros,  # mfy_sismique_qs,
    zeros,  # mfz_sismique_qs,
    zeros,  # mfy_sismique,
    zeros,  # mfz_sismique,
    pression=1e6,
    coude=True,
    asnr=False,  # eq. to FORME = 'RCC_MRX'
)
post_roche_analytic_Coude.calcul_ressort()
post_roche_analytic_Coude.calcul_abattement()
post_roche_analytic_Coude.calc_moment_abat()
post_roche_analytic_Coude.calcul_sigma_eq()

# tout + coude avec CONT_ABAT=DT
post_roche_analytic_Coude_DT = PostRocheAnalytic(
    mfy_poids_propre,
    mt_deplacement_impose,
    zeros,  # mfy_sismique_dyn,
    zeros,  # mfz_sismique_dyn,
    zeros,  # mfy_sismique_qs,
    zeros,  # mfz_sismique_qs,
    zeros,  # mfy_sismique,
    zeros,  # mfz_sismique,
    pression=1e6,
    coude=True,
    asnr=False,  # eq. to FORME = 'RCC_MRX'
    codifie=False,  # eq. to CONT_ABAT = 'DT'
)
post_roche_analytic_Coude_DT.calcul_ressort()
post_roche_analytic_Coude_DT.calcul_abattement()
post_roche_analytic_Coude_DT.calc_moment_abat()
post_roche_analytic_Coude_DT.calcul_sigma_eq()

# tout + coude FORME='ASRN'
post_roche_analytic_Coude_ASNR = PostRocheAnalytic(
    mfy_poids_propre,
    mt_deplacement_impose,
    zeros,  # mfy_sismique_dyn,
    zeros,  # mfz_sismique_dyn,
    zeros,  # mfy_sismique_qs,
    zeros,  # mfz_sismique_qs,
    zeros,  # mfy_sismique,
    zeros,  # mfz_sismique,
    pression=1e6,
    coude=True,
    asnr=True,  # eq. to FORME = 'ASRN'
    codifie=False,  # eq. to CONT_ABAT = 'DT'
)

# Attention : lorsque FORME='ASRN' (asrn=True), que ce soit la valeur de codifie (True/False)
# on prendre toujours la formule DT pour calculer UT02-X9

post_roche_analytic_Coude_ASNR.calcul_ressort()
post_roche_analytic_Coude_ASNR.calcul_abattement()
post_roche_analytic_Coude_ASNR.calc_moment_abat()
post_roche_analytic_Coude_ASNR.calcul_sigma_eq()

# 1- deplacement (D)
post_roche_analytic_D = PostRocheAnalytic(
    zeros, mt_deplacement_impose, zeros, zeros, zeros, zeros, zeros, zeros
)
post_roche_analytic_D.calcul_ressort()
post_roche_analytic_D.calcul_abattement()
post_roche_analytic_D.calcul_sigma_eq()

# 2- deplacement + pression (DP)
post_roche_analytic_DP = PostRocheAnalytic(
    zeros, mt_deplacement_impose, zeros, zeros, zeros, zeros, zeros, zeros, pression=1e6
)
post_roche_analytic_DP.calcul_ressort()
post_roche_analytic_DP.calcul_abattement()
post_roche_analytic_DP.calcul_sigma_eq()

# 3- deplacement + pression + poids propre (DPG)
post_roche_analytic_DPG = PostRocheAnalytic(
    mfy_poids_propre, mt_deplacement_impose, zeros, zeros, zeros, zeros, zeros, zeros, pression=1e6
)
post_roche_analytic_DPG.calcul_ressort()
post_roche_analytic_DPG.calcul_abattement()
post_roche_analytic_DPG.calcul_sigma_eq()


# 4- pression + poids propre (PG)
post_roche_analytic_PG = PostRocheAnalytic(
    mfy_poids_propre,
    zeros,
    zeros,  # mfy_sismique_dyn,
    zeros,  # mfz_sismique_dyn,
    zeros,  # mfy_sismique_qs,
    zeros,  # mfz_sismique_qs,
    zeros,  # mfy_sismique,
    zeros,  # mfz_sismique,
    pression=1e6,
)
post_roche_analytic_PG.calcul_ressort()
post_roche_analytic_PG.calcul_abattement()
post_roche_analytic_PG.calcul_sigma_eq()


E = 2.0e11
K = 0.01
N = 2


def epsi(sig):
    return sig / E + K * pow(sig / E, 1 / N)


def epsiMp(sig):
    return K * pow(sig / E, 1 / N)


