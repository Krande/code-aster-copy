DEBUT(CODE="OUI")

MAIL0 = LIRE_MAILLAGE()

MAILLAGE = CREA_MAILLAGE(MAILLAGE=MAIL0, CREA_POI1=_F(NOM_GROUP_MA="PRADIER", GROUP_NO="SRADIER"))

MAILLAGE = DEFI_GROUP(
    reuse=MAILLAGE,
    MAILLAGE=MAILLAGE,
    CREA_GROUP_MA=(
        _F(
            NOM="centre_ALL",
            TYPE_MAILLE="POI1",
            UNION=("centre_X", "centre_Y", "centre_Z", "centre_RX", "centre_RY"),
        ),
        _F(NOM="RESSORT_ALL", TYPE_MAILLE="SEG2", UNION=("GX", "GY", "GZ", "GRX", "GRY")),
    ),
)

