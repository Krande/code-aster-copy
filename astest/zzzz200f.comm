CONDLIM_LIAIS = AFFE_CHAR_MECA(
    MODELE=STICKMOD,
    LIAISON_SOLIDE=(
        _F(GROUP_NO=("centre_RX", "NG_LIAIS_RX")),
        _F(GROUP_NO=("centre_RY", "NG_LIAIS_RY")),
        _F(GROUP_NO=("centre_X", "NG_LIAIS_X")),
        _F(GROUP_NO=("centre_Y", "NG_LIAIS_Y")),
        _F(GROUP_NO=("centre_Z", "NG_LIAIS_Z")),
    ),
)

CONDLIM = AFFE_CHAR_MECA(
    MODELE=STICKMOD,
    DDL_IMPO=(
        _F(GROUP_NO="centre_X", DX=0, DY=0, DZ=0, DRX=0, DRY=0, DRZ=0),
        _F(GROUP_NO="centre_Y", DX=0, DY=0, DZ=0, DRX=0, DRY=0, DRZ=0),
        _F(GROUP_NO="centre_Z", DX=0, DY=0, DZ=0, DRZ=0),
        _F(GROUP_NO="centre_RX", DX=0, DY=0, DRX=0, DRZ=0),
        _F(GROUP_NO="centre_RY", DX=0, DY=0, DRY=0, DRZ=0),
    ),
)

#
# LA STRUCTURE EST RIGIDIFIEE A L INTERFACE
# ------------------------------------------


COND_LIM = AFFE_CHAR_MECA(
    MODELE=STICKMOD,
    LIAISON_SOLIDE=(_F(GROUP_NO=("HRADIER",)), _F(GROUP_NO=("SRADIER",))),
    LIAISON_UNIF=(_F(GROUP_MA="RLN_4", DDL="DX"), _F(GROUP_MA="RLN_4", DDL="DRY")),
)


# CALCUL DE LA MASSE ET INERTIES DE LA STRUCTURE -----------------------

RIGI_ELE = CALC_MATR_ELEM(
    MODELE=STICKMOD,
    OPTION="RIGI_MECA",
    CHARGE=(COND_LIM, CONDLIM_LIAIS, CONDLIM),
    CHAM_MATER=CHAMPMAT,
    CARA_ELEM=CARA_ELE,
)

MASS_ELE = CALC_MATR_ELEM(
    MODELE=STICKMOD,
    OPTION="MASS_MECA",
    CHARGE=(COND_LIM, CONDLIM_LIAIS, CONDLIM),
    CHAM_MATER=CHAMPMAT,
    CARA_ELEM=CARA_ELE,
)

NUMEDDL = NUME_DDL(MATR_RIGI=RIGI_ELE)

RIGIDITE = ASSE_MATRICE(MATR_ELEM=RIGI_ELE, NUME_DDL=NUMEDDL)

MASSE = ASSE_MATRICE(MATR_ELEM=MASS_ELE, NUME_DDL=NUMEDDL)


MODE = CALC_MODES(
    MATR_RIGI=RIGIDITE,
    MATR_MASS=MASSE,
    OPTION="BANDE",
    CALC_FREQ=_F(FREQ=(0.0, 15.0)),
    VERI_MODE=_F(SEUIL=0.1, STOP_ERREUR="NON"),
    NORM_MODE=_F(NORME="TRAN_ROTA"),
    FILTRE_MODE=_F(CRIT_EXTR="MASS_EFFE_UN"),
    IMPRESSION=_F(CUMUL="NON"),
)


TEST_RESU(
    RESU=(
        _F(NUME_ORDRE=1, PARA="FREQ", RESULTAT=MODE, VALE_CALC=3.95632694470227, CRITERE="RELATIF"),
        _F(
