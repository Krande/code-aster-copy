        ),
        _F(
            GROUP_NO="PT04",
            INST=0.0,
            REFERENCE="ANALYTIQUE",
            RESULTAT=resu_xyz,
            NOM_CHAM="DEPL",
            NOM_CMP="DY",
            VALE_CALC=1.0007859395953105,
            VALE_REFE=1.0,
            CRITERE="RELATIF",
            PRECISION=2e-3,
        ),
        _F(
            GROUP_NO="PT01",
            INST=0.0,
            REFERENCE="ANALYTIQUE",
            RESULTAT=resu_xyz,
            NOM_CHAM="DEPL",
            NOM_CMP="DZ",
            VALE_CALC=0.9927632183416352,
            VALE_REFE=1.0,
