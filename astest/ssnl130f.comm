            INST=0.0,
            REFERENCE="ANALYTIQUE",
            RESULTAT=resu_xyz,
            NOM_CHAM="DEPL",
            NOM_CMP="DZ",
            VALE_CALC=0.9927632185937411,
            VALE_REFE=1.0,
            CRITERE="RELATIF",
            PRECISION=8 - 3,
        ),
    )
)

