        ),
        _F(
            GROUP_NO="PT02",
            INST=0.0,
            REFERENCE="ANALYTIQUE",
            RESULTAT=resu_xyz,
            NOM_CHAM="DEPL",
            NOM_CMP="DZ",
            VALE_CALC=0.99276321842373,
            VALE_REFE=1.0,
            CRITERE="RELATIF",
            PRECISION=8e-3,
        ),
        _F(
            GROUP_NO="PT03",
