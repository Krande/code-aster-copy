            NOM_CHAM="DEPL",
            NOM_CMP="DY",
            VALE_CALC=1.00078593959401,
            VALE_REFE=1.0,
            CRITERE="RELATIF",
            PRECISION=2e-3,
        ),
        _F(
            GROUP_NO="PT02",
            INST=0.0,
            REFERENCE="ANALYTIQUE",
            RESULTAT=resu_xyz,
            NOM_CHAM="DEPL",
            NOM_CMP="DY",
            VALE_CALC=0.9989403294797641,
            VALE_REFE=1.0,
            CRITERE="RELATIF",
            PRECISION=2e-3,
        ),
        _F(
