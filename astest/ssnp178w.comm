########################################################################
#          TEST DE VERIFICATION EN PLASTICITE INCOMPRESSIBLE           #
#                       MEMBRANE DE COOK                               #
########################################################################

DEBUT(CODE="OUI", ERREUR=_F(ALARME="EXCEPTION"), DEBUG=_F(SDVERI="OUI"))


mesh_quad = LIRE_MAILLAGE(FORMAT="MED")

mesh = CREA_MAILLAGE(MAILLAGE=mesh_quad, QUAD_LINE=_F(TOUT="OUI"))

mesh = MODI_MAILLAGE(reuse=mesh, MAILLAGE=mesh, ORIE_PEAU=_F(GROUP_MA_PEAU=("Encast", "load")))

model = AFFE_MODELE(
    AFFE=_F(MODELISATION="3D_MIX_STA", FORMULATION="STA_INCO", PHENOMENE="MECANIQUE", TOUT="OUI"),
    MAILLAGE=mesh,
)

mater = DEFI_MATERIAU(
    ECRO_LINE=_F(D_SIGM_EPSI=0.13474, SY=0.243),
    ELAS=_F(E=70.0, NU=0.4999),
    NON_LOCAL=_F(TAU_EPSI=1 / 16),
)

fieldmat = AFFE_MATERIAU(AFFE=_F(MATER=(mater,), TOUT="OUI"), MAILLAGE=mesh, MODELE=model)

rampe = DEFI_FONCTION(
    NOM_PARA="INST", VALE=(0.0, 0.0, 1.0, 1.0), PROL_DROITE="LINEAIRE", PROL_GAUCHE="EXCLU"
)

listr = DEFI_LIST_REEL(
    DEBUT=0.0,
    INTERVALLE=(_F(JUSQU_A=0.3, NOMBRE=1), _F(JUSQU_A=0.8, NOMBRE=5), _F(JUSQU_A=1.0, NOMBRE=8)),
)

times = DEFI_LIST_INST(
    DEFI_LIST=_F(LIST_INST=listr), ECHEC=_F(ACTION="DECOUPE", EVENEMENT="ERREUR", SUBD_NIVEAU=3)
)

depl = AFFE_CHAR_CINE(
    MECA_IMPO=_F(DX=0.0, DY=0.0, DZ=0.0, GROUP_MA=("Encast",)), MODELE=model, INFO=1
)

plan = AFFE_CHAR_CINE(MECA_IMPO=_F(DZ=0.0, TOUT="OUI"), MODELE=model, INFO=1)

FY = FORMULE(NOM_PARA=("INST"), VALE="0.1125")

load = AFFE_CHAR_MECA_F(FORCE_FACE=_F(FY=FY, GROUP_MA=("load",)), MODELE=model)

resnonl = STAT_NON_LINE(
    CHAM_MATER=fieldmat,
    COMPORTEMENT=_F(DEFORMATION="PETIT", RELATION="VMIS_ISOT_LINE", TOUT="OUI"),
    CONVERGENCE=_F(ITER_GLOB_MAXI=10, RESI_REFE_RELA=1e-3, SIGM_REFE=0.243, LAGR_REFE=0.243 / 70.0),
    EXCIT=(
        _F(CHARGE=depl, TYPE_CHARGE="FIXE_CSTE"),
        _F(CHARGE=plan, TYPE_CHARGE="FIXE_CSTE"),
        _F(CHARGE=load, FONC_MULT=rampe, TYPE_CHARGE="FIXE_CSTE"),
    ),
    INCREMENT=_F(LIST_INST=times),
    MODELE=model,
    NEWTON=_F(MATRICE="TANGENTE", PREDICTION="TANGENTE", REAC_ITER=1),
    SOLVEUR=_F(METHODE="MUMPS"),
    INFO=1,
)


resnonl = CALC_CHAMP(
    reuse=resnonl, CHAM_MATER=fieldmat, CRITERES=("SIEQ_NOEU",), MODELE=model, RESULTAT=resnonl
)


TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("A",),
        REFERENCE="AUTRE_ASTER",
        RESULTAT=resnonl,
        NOM_CHAM="DEPL",
        NOM_CMP="DY",
        VALE_CALC=2.087299523292,
        VALE_REFE=2.13651,
        CRITERE="RELATIF",
        PRECISION=3.0e-2,
    )
)

TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("A",),
        REFERENCE="AUTRE_ASTER",
        RESULTAT=resnonl,
        NOM_CHAM="DEPL",
        NOM_CMP="DX",
        VALE_CALC=-1.577745691,
        VALE_REFE=-1.61818,
        CRITERE="RELATIF",
        PRECISION=3.0e-2,
    )
)

TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("A",),
        REFERENCE="AUTRE_ASTER",
        RESULTAT=resnonl,
        NOM_CHAM="DEPL",
        NOM_CMP="DZ",
        VALE_CALC=0.0,
        VALE_REFE=0.0,
        CRITERE="ABSOLU",
        ORDRE_GRANDEUR=1e-10,
        PRECISION=1.0e-2,
    )
)

TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("A",),
        RESULTAT=resnonl,
        NOM_CHAM="SIEQ_NOEU",
        NOM_CMP="TRSIG",
        VALE_CALC=0.017921555065,
        CRITERE="RELATIF",
    )
)

TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("C",),
        RESULTAT=resnonl,
        NOM_CHAM="DEPL",
        NOM_CMP="DY",
        VALE_CALC=0.357277367913,
        CRITERE="RELATIF",
    )
)

TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("C",),
        RESULTAT=resnonl,
        NOM_CHAM="DEPL",
        NOM_CMP="DX",
        VALE_CALC=-0.0266791748,
        CRITERE="RELATIF",
    )
)

TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("C",),
        RESULTAT=resnonl,
        NOM_CHAM="DEPL",
        NOM_CMP="DZ",
        VALE_CALC=0.0,
        ORDRE_GRANDEUR=1e-10,
        CRITERE="ABSOLU",
    )
)

TEST_RESU(
    RESU=_F(
        INST=1.0,
        GROUP_NO=("C",),
        RESULTAT=resnonl,
        NOM_CHAM="SIEQ_NOEU",
        NOM_CMP="TRSIG",
        VALE_CALC=0.38531716873,
        CRITERE="RELATIF",
    )
)

IMPR_RESU(FORMAT="MED", RESU=_F(RESULTAT=resnonl), UNITE=80)


FIN()
